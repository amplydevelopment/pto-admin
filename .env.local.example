# Copy to .env.local and fill in. NEVER commit .env.local anywhere.

# Supabase (Amply project) — dashboard > Settings > API
SUPABASE_URL=https://aaiyycxehewdkzvallvf.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ClickUp — used by "Import from ClickUp" to fetch a task server-side.
# Must be a privileged (owner/admin) token so it can read the hidden
# Employee/Duration fields. Sent raw as the Authorization header (no "Bearer").
CLICKUP_TOKEN=

# Slack — used ONLY by the opt-in notifications on "Add PTO" (upcoming approved
# leaves). Bot User OAuth token (xoxb-…) from the "Amply Bot" app's
# OAuth & Permissions page. Needs scopes: chat:write, users:read.email, im:write.
# Same bot the n8n workflow uses. Leave blank to disable notifications.
SLACK_BOT_TOKEN=
# The #pto channel id (defaults to C09LJBZN88L if unset).
SLACK_PTO_CHANNEL=

# Auth
# Generate with: openssl rand -base64 32
AUTH_SECRET=
# Shared password for the local/dev login (everyone uses the same one for now)
APP_DEV_PASSWORD=

# Safety: while "true" (default), every write action is blocked server-side.
# Set to "false" ONLY when writes to the Amply database are intentionally enabled.
READ_ONLY=true
