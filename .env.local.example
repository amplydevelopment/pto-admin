# Copy to .env.local and fill in. NEVER commit .env.local anywhere.

# Supabase (Amply project) — dashboard > Settings > API
SUPABASE_URL=https://aaiyycxehewdkzvallvf.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Auth
# Generate with: openssl rand -base64 32
AUTH_SECRET=
# Shared password for the local/dev login (everyone uses the same one for now)
APP_DEV_PASSWORD=

# Safety: while "true" (default), every write action is blocked server-side.
# Set to "false" ONLY when writes to the Amply database are intentionally enabled.
READ_ONLY=true
